    <item>
      <title>재개발 수익성 시뮬레이터</title>
      <link>http://localhost:1313/redev-tool/</link>
      <pubDate>Thu, 12 Mar 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/redev-tool/</guid>
      <description>&lt;style&gt;
  /* 1. 사이트 최상단 로고/제목 영역 및 여백 완벽 제거 */
  header.header, .post-title, .post-meta, .post-header {
    display: none !important;
  }
  
  /* 2. 본문을 천장까지 밀착 */
  .main {
    margin-top: 0 !important;
    padding-top: 0 !important;
    max-width: 100% !important;
  }

  /* 3. 배경색 고정 */
  body {
    background-color: #ffffff !important;
  }
&lt;/style&gt;
&lt;div style=&#34;background-color: #FF6600 !important; padding: 40px 20px; text-align: center; border-bottom: 6px solid #e65c00; margin-bottom: 50px; box-shadow: 0 4px 20px rgba(0,0,0,0.2);&#34;&gt;
    &lt;h1 style=&#34;margin: 0 !important; color: #FFFFFF !important; font-family: &#39;Pretendard&#39;, sans-serif; text-shadow: 2px 2px 4px rgba(0,0,0,0.3) !important;&#34;&gt;
        &lt;span style=&#34;font-size: 28px !important; font-weight: 800 !important; color: #FFFFFF !important; display: block; margin-bottom: 10px;&#34;&gt;행정력? 지금은 실행력!&lt;/span&gt;
        &lt;span style=&#34;font-size: 46px !important; font-weight: 900 !important; letter-spacing: -1px !important; color: #FFFFFF !important; display: block;&#34;&gt;기호 4번 개혁신당 구의원 후보 정민우 🍊&lt;/span&gt;
        &lt;span style=&#34;font-size: 24px !important; font-weight: 700 !important; color: #FFFFFF !important; display: block; margin-top: 10px; opacity: 0.9;&#34;&gt;(천호1동, 천호3동)&lt;/span&gt;
    &lt;/h1&gt;
&lt;/div&gt;
&lt;div id=&#34;sim-container&#34; style=&#34;max-width:650px;margin:20px auto;padding:30px;border-radius:20px;background-color:#ffffff;box-shadow:0 15px 40px rgba(0,0,0,0.15);font-family:&#39;Pretendard&#39;,sans-serif;color:#333;&#34;&gt;
&lt;h2 style=&#34;text-align:center;color:#FF6600;margin-bottom:25px;font-weight:800;&#34;&gt;🏙️ 재개발 수익성 정밀 분석&lt;/h2&gt;
&lt;div style=&#34;background:#fff9f5;padding:20px;border-radius:15px;margin-bottom:25px;border:1px solid #ffe0cc;&#34;&gt;
&lt;div style=&#34;display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:15px;&#34;&gt;
&lt;div&gt;&lt;label style=&#34;font-weight:700;font-size:14px;&#34;&gt;🏠 주택 유형&lt;/label&gt;&lt;select id=&#34;houseType&#34; style=&#34;width:100%;padding:12px;border:1px solid #ddd;border-radius:10px;margin-top:5px;&#34;&gt;&lt;option value=&#34;collective&#34;&gt;공동주택 (빌라)&lt;/option&gt;&lt;option value=&#34;single&#34;&gt;단독 / 다가구&lt;/option&gt;&lt;/select&gt;&lt;/div&gt;
&lt;div&gt;&lt;label style=&#34;font-weight:700;font-size:14px;&#34;&gt;💰 현재 공시가격 (원)&lt;/label&gt;&lt;input type=&#34;number&#34; id=&#34;publicPrice&#34; value=&#34;271000000&#34; style=&#34;width:100%;padding:12px;border:1px solid #ddd;border-radius:10px;margin-top:5px;box-sizing:border-box;&#34;&gt;&lt;a href=&#34;https://www.realtyprice.kr&#34; target=&#34;_blank&#34; style=&#34;display:block;margin-top:10px;padding:10px;background:#FF6600;color:#ffffff;text-align:center;text-decoration:none;border-radius:8px;font-size:14px;font-weight:bold;box-shadow:0 2px 5px rgba(255,102,0,0.2);&#34;&gt;공시지가확인 🔍&lt;/a&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;div style=&#34;display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:15px;&#34;&gt;
&lt;div&gt;&lt;label style=&#34;font-weight:700;font-size:14px;color:#d35400;&#34;&gt;🎯 예상 조합원 분양가&lt;/label&gt;&lt;input type=&#34;number&#34; id=&#34;memberPrice&#34; placeholder=&#34;예: 900000000&#34; style=&#34;width:100%;padding:12px;border:1px solid #ddd;border-radius:10px;margin-top:5px;&#34;&gt;&lt;/div&gt;
&lt;div&gt;&lt;label style=&#34;font-weight:700;font-size:14px;color:#27ae60;&#34;&gt;📈 입주 시 예상 시세&lt;/label&gt;&lt;input type=&#34;number&#34; id=&#34;futurePrice&#34; placeholder=&#34;예: 1500000000&#34; style=&#34;width:100%;padding:12px;border:1px solid #ddd;border-radius:10px;margin-top:5px;&#34;&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;div style=&#34;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;&#34;&gt;
&lt;div&gt;&lt;label style=&#34;font-size:11px;font-weight:bold;&#34;&gt;🏦 대출(%)&lt;/label&gt;&lt;input type=&#34;number&#34; id=&#34;loanRatio&#34; value=&#34;50&#34; style=&#34;width:100%;padding:8px;border:1px solid #eee;&#34;&gt;&lt;/div&gt;
&lt;div&gt;&lt;label style=&#34;font-size:11px;font-weight:bold;&#34;&gt;📈 금리(%)&lt;/label&gt;&lt;input type=&#34;number&#34; id=&#34;loanRate&#34; value=&#34;4.5&#34; step=&#34;0.1&#34; style=&#34;width:100%;padding:8px;border:1px solid #eee;&#34;&gt;&lt;/div&gt;
&lt;div&gt;&lt;label style=&#34;font-size:11px;font-weight:bold;&#34;&gt;📅 기간(월)&lt;/label&gt;&lt;input type=&#34;number&#34; id=&#34;duration&#34; value=&#34;48&#34; style=&#34;width:100%;padding:8px;border:1px solid #eee;&#34;&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;button onclick=&#34;calculateRedevPro()&#34; style=&#34;width:100%;padding:20px;background:#2c3e50;color:white;border:none;border-radius:12px;font-size:18px;font-weight:bold;cursor:pointer;box-shadow:0 4px 10px rgba(0,0,0,0.2);&#34;&gt;실행력 있는 분석 시작&lt;/button&gt;
&lt;div id=&#34;resultArea&#34; style=&#34;display:none;margin-top:30px;&#34;&gt;&lt;div style=&#34;background:#f8f9fa;padding:20px;border-radius:15px;border-top:5px solid #FF6600;&#34;&gt;&lt;h4 style=&#34;margin:0 0 15px 0;color:#FF6600;&#34;&gt;📋 상세 자금 명세&lt;/h4&gt;&lt;div style=&#34;display:flex;justify-content:space-between;margin:8px 0;&#34;&gt;&lt;span&gt;예상 권리가액&lt;/span&gt;&lt;span id=&#34;resAppraisal&#34;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&#34;display:flex;justify-content:space-between;margin:8px 0;&#34;&gt;&lt;span&gt;추가 분담금&lt;/span&gt;&lt;span id=&#34;resContribution&#34; style=&#34;color:#e74c3c;font-weight:bold;&#34;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&#34;display:flex;justify-content:space-between;margin:8px 0;&#34;&gt;&lt;span&gt;이주비 대출 이자&lt;/span&gt;&lt;span id=&#34;resInterest&#34;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&#34;display:flex;justify-content:space-between;margin:8px 0;border-bottom:1px solid #ddd;padding-bottom:10px;&#34;&gt;&lt;span&gt;예상 취득세&lt;/span&gt;&lt;span id=&#34;resTax&#34;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&#34;margin-top:15px;display:flex;justify-content:space-between;align-items:center;&#34;&gt;&lt;span style=&#34;font-weight:bold;&#34;&gt;총 투자 원가&lt;/span&gt;&lt;span id=&#34;resTotalCost&#34; style=&#34;font-size:20px;font-weight:800;color:#2c3e50;&#34;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&#34;margin-top:20px;padding:15px;background:#27ae60;color:white;border-radius:10px;text-align:center;&#34;&gt;&lt;p style=&#34;margin:0;font-size:14px;&#34;&gt;예상 시세차익 (수익)&lt;/p&gt;</description>
    </item>
    <item>
      <title>천호동 재개발 분담금 시뮬레이터</title>
      <link>http://localhost:1313/calculator/</link>
      <pubDate>Wed, 11 Mar 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/calculator/</guid>
      <description>&lt;h3 id=&#34;-내-집의-가치-데이터로-확인하십시오&#34;&gt;🏗️ 내 집의 가치, 데이터로 확인하십시오.&lt;/h3&gt;
&lt;p&gt;정확한 데이터가 주민의 재산을 지킵니다.&lt;/p&gt;
&lt;div id=&#34;calculator-box&#34; style=&#34;border: 2px solid #ff5a00; padding: 20px; border-radius: 10px; background-color: #fff9f5; color: #333;&#34;&gt;
&lt;label style=&#34;font-weight: bold;&#34;&gt;현재 내 집의 대지 지분 (평): &lt;/label&gt;
&lt;input type=&#34;number&#34; id=&#34;current-land&#34; value=&#34;10&#34; style=&#34;width: 100px; padding: 5px; border: 1px solid #ccc; border-radius: 4px;&#34;&gt;&lt;br&gt;&lt;br&gt;
&lt;p&gt;&lt;label style=&#34;font-weight: bold;&#34;&gt;현재 시세 (3.3㎡당, 만원): &lt;/label&gt;
&lt;input type=&#34;number&#34; id=&#34;market-price&#34; value=&#34;3000&#34; style=&#34;width: 100px; padding: 5px; border: 1px solid #ccc; border-radius: 4px;&#34;&gt;&lt;br&gt;&lt;br&gt;&lt;/p&gt;
&lt;p&gt;&lt;label style=&#34;font-weight: bold;&#34;&gt;희망하는 새 아파트 평형: &lt;/label&gt;
&lt;select id=&#34;target-size&#34; style=&#34;padding: 5px; border: 1px solid #ccc; border-radius: 4px;&#34;&gt;&lt;/p&gt;
&lt;option value=&#34;25&#34;&gt;25평 (59㎡)&lt;/option&gt;
&lt;option value=&#34;34&#34;&gt;34평 (84㎡)&lt;/option&gt;
&lt;/select&gt;&lt;br&gt;&lt;br&gt;
&lt;p&gt;&lt;label style=&#34;font-weight: bold;&#34;&gt;예상 조합원 분양가 (평당, 만원): &lt;/label&gt;
&lt;input type=&#34;number&#34; id=&#34;avg-sale-price&#34; value=&#34;2500&#34; style=&#34;width: 100px; padding: 5px; border: 1px solid #ccc; border-radius: 4px;&#34;&gt;&lt;br&gt;&lt;br&gt;&lt;/p&gt;</description>
    </item>
  </channel>
